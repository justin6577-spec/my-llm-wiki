# HHRI-AI Research Wiki — Environment Variables
# Copy this file to .env (or export these in your shell) and fill in your values.
# NEVER commit .env or any file containing real keys to git.

# ── Option 1: Anthropic public API ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Option 2: Google Vertex AI (enterprise) ─────────────────────────────────
# agent.py / build_wiki.py read these names directly:
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_REGION_CLAUDE_4_6_SONNET=europe-west1
# Model deployment names (optional — sensible defaults are built in):
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6

# ── Wiki configuration ──────────────────────────────────────────────────────
# Path to the wiki repo. Defaults to the script's own directory if unset.
WIKI_VAULT=/path/to/your/wiki/folder

# ── Optional: daily cron (setup_cron.sh) ────────────────────────────────────
CONDA_SH=$HOME/anaconda3/etc/profile.d/conda.sh
CONDA_ENV=base
